APP_NAME="Honest Art"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=evite
DB_USERNAME=evite
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# SendGrid (never commit real keys — use server .env only)
SENDGRID_API_KEY=

# Mail (defaults; admin panel can override via DB for SendGrid/SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: transactional email via Brevo (GuestController)
BREVO_API_KEY=
BREVO_FROM_NAME="Honest Art"
BREVO_FROM_EMAIL="hello@yourdomain.com"

# Admin password reset links in emails
FRONTEND_ADMIN_URL=https://app.yourdomain.com
# FRONTEND_URL=https://app.yourdomain.com

# Sanctum: production frontend host(s), comma-separated
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com,www.yourdomain.com

# Email health alerts (optional cron / CheckEmailHealth command)
EMAIL_ALERT_WINDOW_HOURS=24
EMAIL_BOUNCE_ALERT_THRESHOLD=3
EMAIL_SPAM_ALERT_THRESHOLD=0.2
EMAIL_ALERT_RECIPIENTS=
